# ── Database Configuration ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexpath
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── Security & JWT ──────────────────────────────────────────────────────────
# Generate a strong 256-bit secret (e.g., base64)
JWT_SECRET=your_jwt_secret_here

# ── OAuth2 Social Login (Google) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Razorpay Payment Integration ─────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── AI Providers (Spring AI) ────────────────────────────────────────────────
# Provider choice: openrouter | ollama
AI_PROVIDER=openrouter

# OpenRouter (Primary)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxx

# Ollama (Local Fallback - optional)
OLLAMA_BASE_URL=http://localhost:11434

# ── Redis (Caching) ─────────────────────────────────────────────────────────
# Format: redis://host:port or redis://user:password@host:port
REDIS_URL=redis://localhost:6379

# ── App URLs ────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5173
SERVER_PORT=8080
